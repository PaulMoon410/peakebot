# Server Port
PORT=3000

# Node Environment
NODE_ENV=development

# Frontend URL (for CORS - set to Geocities URL after deployment)
FRONTEND_URL=https://geocities.ws/peakecoin/ai

# Python knowledge server bridge
PYTHON_KNOWLEDGE_SERVER=http://localhost:5001
PYTHON_PORT=5001
PYTHON_CHAT_TIMEOUT_MS=90000
START_PYTHON_SERVER=true

# FTP Configuration (for saving conversations to Geocities)
FTP_HOST=ftp.geocities.ws
FTP_USER=PeakeCoin
FTP_PASSWORD=Peake410
FTP_BRAIN_DIR=/ai/brain
SEARCH_MAX_FILES=0
KNOWLEDGE_MAX_FILE_MB=10
FTP_AI_KNOW_DIR=/ai/brain
TERM_KNOWLEDGE_FILE=term_knowledge.json
TERM_CACHE_TTL_SECONDS=300
SEARCH_CACHE_TTL_SECONDS=120
CHAT_SEARCH_RETRIES=3

# Python memory engine behavior
KNOWLEDGE_ENGINE=memory-retrieval
ENABLE_CROSS_VERIFY=true
KNOWLEDGE_LOG_LEVEL=INFO

# Background fact-check worker
FACTCHECK_ENABLED=true
FACTCHECK_INTERVAL_SECONDS=1800
FACTCHECK_IDLE_SECONDS=180
FACTCHECK_MAX_ITEMS_PER_RUN=5
FACTCHECK_MAX_RESULTS=3
FACTCHECK_WHITELIST_HOSTS=wikipedia.org,gov,edu
FACTCHECK_HEARTBEAT_PATH=/ai/brain/factcheck_heartbeat.json
FACTCHECK_STATE_PATH=/ai/brain/factcheck_state.json
FACTCHECK_FACTS_PATH=/ai/brain/factcheck_facts.json
FACTCHECK_WORKER_STATUS_PATH=/tmp/factcheck_worker_status.json
FACTCHECK_FACTS_MAX_FILE_MB=10
FACTCHECK_AGGRESSIVE_IDLE_INTERVAL=10
FACTCHECK_LOG_LEVEL=INFO
