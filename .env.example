# Server Port
PORT=3000

# Node Environment
NODE_ENV=development

# Frontend URL (for CORS - set to Geocities URL after deployment)
FRONTEND_URL=https://geocities.ws/peakecoin/ai

# Python knowledge server bridge
PYTHON_KNOWLEDGE_SERVER=http://localhost:5001
PYTHON_PORT=5001
START_PYTHON_SERVER=true

# FTP Configuration (for saving conversations to Geocities)
FTP_HOST=ftp.geocities.ws
FTP_USER=PeakeCoin
FTP_PASSWORD=Peake410
FTP_BRAIN_DIR=/ai/brain
SEARCH_MAX_FILES=0

# Python memory engine behavior
KNOWLEDGE_ENGINE=memory-retrieval
ENABLE_CROSS_VERIFY=true
